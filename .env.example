# Kontrol example environment.
# Copy to a private env file such as ~/.kontrol/kontrol.env or .env, then edit.
# Keep secret-bearing files mode 0600.

HOST=127.0.0.1
PORT=7676

# Comma-separated local roots that MCP workspaces may open.
KONTROL_ALLOWED_ROOTS=$HOME/projects,$HOME/work

# Public origin for OAuth/public tunnel mode. Do not include /mcp.
# KONTROL_PUBLIC_BASE_URL=https://kontrol.example.com

# Auth mode:
# - oauth: public/reverse-proxy deployments with owner approval
# - tunnel: loopback-only OpenAI Secure MCP Tunnel deployments
KONTROL_AUTH_MODE=oauth

# Owner password for non-interactive/env-driven OAuth deployments.
# Generate with: openssl rand -base64 32
# KONTROL_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret
# KONTROL_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# KONTROL_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# KONTROL_OAUTH_SCOPES=kontrol
# KONTROL_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1

# Tunnel defense-in-depth token. In tunnel mode this can be injected by the
# OpenAI tunnel client with --mcp.extra-headers "Authorization: Bearer $KONTROL_TUNNEL_TOKEN".
# KONTROL_TUNNEL_TOKEN=change-me-to-a-long-random-secret

# Optional Host header allowlist override. Avoid "*" outside local debugging.
# KONTROL_ALLOWED_HOSTS=localhost,127.0.0.1,kontrol.example.com

# Tool and widget surface.
KONTROL_TOOL_MODE=minimal
KONTROL_WIDGETS=full

# State and managed worktrees.
# KONTROL_STATE_DIR=$HOME/.local/share/kontrol
# KONTROL_WORKTREE_ROOT=$HOME/.kontrol/worktrees

# Skills are enabled by default. Set to 0 to hide them.
# KONTROL_SKILLS=1
# KONTROL_AGENT_DIR=$HOME/.codex
# KONTROL_SKILL_PATHS=$HOME/.agents/skills,$HOME/.claude/skills

# Logging.
KONTROL_LOG_LEVEL=info
KONTROL_LOG_FORMAT=json
KONTROL_LOG_REQUESTS=1
KONTROL_LOG_ASSETS=0
KONTROL_LOG_TOOL_CALLS=1
KONTROL_LOG_SHELL_COMMANDS=0
# KONTROL_TRUST_PROXY=1

# ACP control plane and adapter secrets.
# Generate each secret independently with: openssl rand -base64 32
# KONTROL_ACP_ENABLED=1
# KONTROL_ACP_SHARED_SECRET=legacy-shared-secret
# KONTROL_ACP_AGENT_SECRET=agent-registration-secret
# KONTROL_ACP_REVIEWER_SECRET=reviewer-control-secret
# KONTROL_ACP_ADAPTER_SECRET=adapter-ingress-secret
# KONTROL_ACP_AGENTS=http://127.0.0.1:9877,http://127.0.0.1:9911
# KONTROL_ACP_URL=http://127.0.0.1:7676/acp

# Worker bridge used inside CLI-agent MCP config.
# KONTROL_BRIDGE_URL=http://127.0.0.1:7676/mcp
# KONTROL_BRIDGE_ENV=$HOME/.kontrol/kontrol.env

# CRUSH adapter.
# ACP_AGENT_BIN=crush
# CRUSH_BIN=crush
# ACP_ADAPTER_PORT=9877
# ACP_ADAPTER_REPLAY_STORE=/tmp/kontrol-acp-adapter-replay.json

# Hermes native adapter.
# HERMES_BIN=hermes
# HERMES_AGENT_ROOT=/path/to/hermes-agent
# HERMES_NATIVE_PYTHON=/path/to/hermes-agent/.venv/bin/python
# HERMES_ACP_ADAPTER_PORT=9911
